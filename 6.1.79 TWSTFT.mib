------------SNMPV2-NOTIFICATIONS-----------------------------------




TwstftGnssPosFix_Available NOTIFICATION-TYPE
    OBJECTS     { GnssPos }
    STATUS      current
    DESCRIPTION
        "GNSS Position Fix Available"
::= { Notifications 1 }

TwstftGnssPosFix_NotAvailable NOTIFICATION-TYPE
    OBJECTS     { GnssPos }
    STATUS      current
    DESCRIPTION
        "GNSS Position Fix Not Available"
         
::= { Notifications 2 }


TwstftOscLock_Available NOTIFICATION-TYPE
	OBJECTS     { OscLock }
    	STATUS      current
    	DESCRIPTION
    	 " TWSTFT Oscillator lock available"
 ::= { Notifications 3 }  
 
 TwstftOscLock_NotAvailable NOTIFICATION-TYPE
 	OBJECTS     { OscLock }
     	STATUS      current
     	DESCRIPTION
     	 " TWSTFT Oscillator lock available"
 ::= { Notifications 4 }
 
 Twstft_Synced NOTIFICATION-TYPE
  	OBJECTS     { Sync }
      	STATUS      current
      	DESCRIPTION
      	 " TWSTFT Time unit is in sync"
 ::= { Notifications 5 }
 
 Twstft_Sync_HoldOver NOTIFICATION-TYPE
   	OBJECTS     { Sync }
       	STATUS      current
       	DESCRIPTION
       	" TWSTFT Time unit is not in sync"
 ::= { Notifications 6 }
 
  
 TwstftLinkTransmit_On NOTIFICATION-TYPE
      	OBJECTS     { LinkTransmit }
        STATUS      current
        DESCRIPTION
          " TWSTFT Link Transmission is ON"
 ::= { Notifications 7 }
 
 TwstftLinkTransmit_Off NOTIFICATION-TYPE
       	 OBJECTS     { LinkTransmit }
         STATUS      current
         DESCRIPTION
           " TWSTFT Link Transmission is Off"
 ::= { Notifications 8 }
 
 TwstftAntenna_Connected NOTIFICATION-TYPE
       	OBJECTS     { Antenna }
       	STATUS      current
        DESCRIPTION
            " TWSTFT Antenna is connected"
 ::= { Notifications 9 }
 
 TwstftAntenna_DisConnected NOTIFICATION-TYPE
         OBJECTS     { Antenna }
         STATUS      current
         DESCRIPTION
             " TWSTFT Antenna is disconnected"
 ::= { Notifications 10 }
 
 
 
 TwstftColdStart NOTIFICATION-TYPE
          OBJECTS     { Power ON }
          STATUS      current
          DESCRIPTION
            " TWSTFT Modem is turned ON"
 ::= { Notifications 11 }
 
 
 TwstftReset NOTIFICATION-TYPE
           OBJECTS     { Reset }
           STATUS      current
           DESCRIPTION
             " TWSTFT Modem Reset"
 ::= { Notifications 12 }
 
-- Twstft_Not_Synced NOTIFICATION-TYPE
--            OBJECTS     { Sync }
--            STATUS      current
--            DESCRIPTION
--              " TWSTFT is not synchronized"
-- ::= { Notifications 13 }
 
-- Twstft_Freq_Correction_Applied NOTIFICATION-TYPE
--             OBJECTS     { Freq Correction }
--             STATUS      current
--             DESCRIPTION
--               " TWSTFT Frequency Correction applied"
-- ::= { Notifications 14 }
 



END





